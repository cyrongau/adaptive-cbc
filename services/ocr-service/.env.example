# OCR Service Environment Variables

# Google Cloud Vision (Primary OCR Engine)
# Option 1: Service account JSON file path (mounted in container)
GOOGLE_APPLICATION_CREDENTIALS=/app/gcp-credentials.json

# Option 2: API key (alternative to service account)
# GOOGLE_VISION_API_KEY=your-api-key-here

# OpenRouter (AI Structuring)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Redis (already configured via docker-compose)
REDIS_URL=redis://redis:6379/0

# MinIO (already configured via docker-compose)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ocr-documents
MINIO_SECURE=false

# Processing
MAX_PAGES=30
OCR_DPI=300
